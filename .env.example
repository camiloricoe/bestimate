# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=scraper
DB_USER=scraper
DB_PASSWORD=changeme

# Redis
REDIS_URL=redis://localhost:6379/0

# Proxy - PacketStream Residential Rotating
# Each request gets a different IP automatically
# Test: curl -x "http://USER:PASS@proxy.packetstream.io:31112" https://ipv4.icanhazip.com
PROXY_USER=your_user
PROXY_PASS=your_pass
PROXY_HOST=proxy.packetstream.io
PROXY_PORT=31112

# Scraping Settings
SCRAPE_DELAY_MIN=3.0
SCRAPE_DELAY_MAX=8.0
MAX_RETRIES=3
WORKERS_CONCURRENCY=4
CIRCUIT_BREAKER_THRESHOLD=0.20

# Monitoring
GRAFANA_PASSWORD=changeme
